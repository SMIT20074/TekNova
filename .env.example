SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key-here

# -------------------------------------------------------------------------
# 2. Frontend Environment Variables (Next.js / client / .env.local)
# Put these in a `.env` or `.env.local` file inside the frontend project.
# -------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://gczvfrtquwtyclpwombu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key-here
